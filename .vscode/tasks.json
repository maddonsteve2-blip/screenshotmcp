{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "deepsyte-extension: build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/packages/vscode-extension"
      },
      "problemMatcher": []
    },
    {
      "label": "deepsyte-extension: watch",
      "type": "shell",
      "command": "npm run watch",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/packages/vscode-extension"
      },
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VS Code extension watch mode started",
          "endsPattern": "VS Code extension watch mode started"
        }
      }
    },
    {
      "label": "deepsyte-extension: typecheck",
      "type": "shell",
      "command": "npm run typecheck",
      "options": {
        "cwd": "${workspaceFolder}/packages/vscode-extension"
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "deepsyte-extension: test",
      "type": "shell",
      "command": "npm test",
      "options": {
        "cwd": "${workspaceFolder}/packages/vscode-extension"
      },
      "problemMatcher": []
    }
  ]
}
