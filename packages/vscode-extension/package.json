{
  "name": "deepsyte-vscode",
  "displayName": "DeepSyte",
  "description": "VS Code extension for DeepSyte: automatic browser OAuth, API key fallback, MCP registration, screenshot commands, and browser tooling.",
  "version": "0.25.0",
  "publisher": "DeepSyte",
  "license": "SEE LICENSE IN LICENSE",
  "private": false,
  "preview": true,
  "pricing": "Free",
  "icon": "images/icon.png",
  "homepage": "https://www.deepsyte.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/stevejford/deepsyte.git",
    "directory": "packages/vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/stevejford/deepsyte/issues"
  },
  "markdown": "github",
  "files": [
    "dist/**",
    "images/**",
    "media/**",
    "snippets/**",
    "schemas/**",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "screenshots",
    "mcp",
    "browser",
    "automation",
    "testing",
    "playwright",
    "seo",
    "accessibility"
  ],
  "activationEvents": [
    "onUri",
    "workspaceContains:**/.vscode/mcp.json",
    "workspaceContains:**/.cursor/mcp.json"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "npm run build",
    "package:vsix": "npx @vscode/vsce package --no-dependencies",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/**/*.test.ts"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "deepsyte",
          "title": "deepsyte",
          "icon": "images/camera.svg"
        }
      ]
    },
    "views": {
      "deepsyte": [
        {
          "id": "deepsyte.sidebar",
          "name": "Home",
          "icon": "images/icon.png"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "deepsyte.chat",
        "fullName": "deepsyte",
        "name": "deepsyte",
        "description": "Capture screenshots, run UX audits, and open packaged workflows.",
        "isSticky": true,
        "commands": [
          {
            "name": "screenshot",
            "description": "Capture a screenshot of a URL (usage: /screenshot https://example.com)"
          },
          {
            "name": "audit",
            "description": "Run a UX/SEO/accessibility audit (usage: /audit https://example.com)"
          },
          {
            "name": "workflow",
            "description": "Open a packaged workflow from an installed skill"
          },
          {
            "name": "timeline",
            "description": "Show recent screenshots and audits"
          },
          {
            "name": "diff",
            "description": "Visual diff between two URLs (usage: /diff https://a https://b)"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "deepsyte.signIn",
        "title": "deepsyte: Sign In"
      },
      {
        "command": "deepsyte.signOut",
        "title": "deepsyte: Sign Out"
      },
      {
        "command": "deepsyte.checkStatus",
        "title": "deepsyte: Check Status"
      },
      {
        "command": "deepsyte.installMcpServer",
        "title": "deepsyte: Configure Editor Integration"
      },
      {
        "command": "deepsyte.syncCoreSkill",
        "title": "deepsyte: Sync Core Skill"
      },
      {
        "command": "deepsyte.browseSkills",
        "title": "deepsyte: Browse Community Skills"
      },
      {
        "command": "deepsyte.installSkill",
        "title": "deepsyte: Install Skill"
      },
      {
        "command": "deepsyte.previewSkill",
        "title": "deepsyte: Preview Skill"
      },
      {
        "command": "deepsyte.takeScreenshot",
        "title": "deepsyte: Take Screenshot"
      },
      {
        "command": "deepsyte.takeScreenshotAtUrl",
        "title": "deepsyte: Take Screenshot of URL"
      },
      {
        "command": "deepsyte.auditUrl",
        "title": "deepsyte: Audit URL"
      },
      {
        "command": "deepsyte.screenshotSelectedUrl",
        "title": "deepsyte: Screenshot Selected URL"
      },
      {
        "command": "deepsyte.auditSelectedUrl",
        "title": "deepsyte: Audit Selected URL"
      },
      {
        "command": "deepsyte.openTimeline",
        "title": "deepsyte: Open Timeline"
      },
      {
        "command": "deepsyte.openDashboard",
        "title": "deepsyte: Open Dashboard"
      },
      {
        "command": "deepsyte.createSkill",
        "title": "deepsyte: Create New Skill"
      },
      {
        "command": "deepsyte.showOutput",
        "title": "deepsyte: Show Output"
      },
      {
        "command": "deepsyte.showQuickActions",
        "title": "deepsyte: Quick Actions"
      },
      {
        "command": "deepsyte.openWorkflow",
        "title": "deepsyte: Open Workflow"
      },
      {
        "command": "deepsyte.clearAuditDiagnostics",
        "title": "deepsyte: Clear Audit Diagnostics"
      },
      {
        "command": "deepsyte.showUrlHistory",
        "title": "deepsyte: Show URL History"
      },
      {
        "command": "deepsyte.showHistoryForSelectedUrl",
        "title": "deepsyte: Show History for Selected URL"
      },
      {
        "command": "deepsyte.diffUrls",
        "title": "deepsyte: Visual Diff (compare two URLs)"
      },
      {
        "command": "deepsyte.editProjectUrls",
        "title": "deepsyte: Edit Project URLs (.deepsyte/urls.json)"
      },
      {
        "command": "deepsyte.runProjectUrls",
        "title": "deepsyte: Screenshot Project URLs"
      },
      {
        "command": "deepsyte.auditProjectUrls",
        "title": "deepsyte: Audit Project URLs"
      },
      {
        "command": "deepsyte.openHtmlReport",
        "title": "deepsyte: Open HTML Report"
      },
      {
        "command": "deepsyte.captureBaseline",
        "title": "deepsyte: Capture Baseline for URL"
      },
      {
        "command": "deepsyte.diffBaseline",
        "title": "deepsyte: Diff URL vs Stored Baseline"
      },
      {
        "command": "deepsyte.editProjectBudget",
        "title": "deepsyte: Edit Project Budget (.deepsyte/budget.json)"
      },
      {
        "command": "deepsyte.watchProjectUrls",
        "title": "deepsyte: Watch Project URLs (run `deepsyte watch`)"
      },
      {
        "command": "deepsyte.showStoredBaselines",
        "title": "deepsyte: Show Stored Baselines"
      },
      {
        "command": "deepsyte.promoteBaseline",
        "title": "deepsyte: Promote Baseline (overwrite stored image)"
      },
      {
        "command": "deepsyte.captureFromClipboard",
        "title": "deepsyte: Capture from Clipboard URL"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "deepsyte.screenshotSelectedUrl",
          "group": "deepsyte@1",
          "when": "editorHasSelection || editorTextFocus"
        },
        {
          "command": "deepsyte.auditSelectedUrl",
          "group": "deepsyte@2",
          "when": "editorHasSelection || editorTextFocus"
        },
        {
          "command": "deepsyte.showHistoryForSelectedUrl",
          "group": "deepsyte@3",
          "when": "editorHasSelection || editorTextFocus"
        }
      ]
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "deepsyte.provider",
        "label": "deepsyte"
      }
    ],
    "walkthroughs": [
      {
        "id": "deepsyte.getStarted",
        "title": "Get started with deepsyte",
        "description": "Sign in, take your first screenshot, and run your first audit — all from VS Code.",
        "steps": [
          {
            "id": "signIn",
            "title": "Sign in to deepsyte",
            "description": "Sign in with your browser (OAuth) or paste an API key.\n[Sign In](command:deepsyte.signIn)",
            "media": {
              "markdown": "media/walkthrough/sign-in.md"
            },
            "completionEvents": [
              "onCommand:deepsyte.signIn"
            ]
          },
          {
            "id": "firstScreenshot",
            "title": "Take your first screenshot",
            "description": "Capture any URL — the result opens inline with open, copy, rerun, and dashboard actions.\n[Take Screenshot](command:deepsyte.takeScreenshot)",
            "media": {
              "markdown": "media/walkthrough/screenshot.md"
            },
            "completionEvents": [
              "onCommand:deepsyte.takeScreenshot"
            ]
          },
          {
            "id": "firstAudit",
            "title": "Run your first audit",
            "description": "Run a UX review on any URL. Findings render as a structured report with a hero screenshot and dashboard deep-link.\n[Audit URL](command:deepsyte.showQuickActions)",
            "media": {
              "markdown": "media/walkthrough/audit.md"
            },
            "completionEvents": [
              "onCommand:deepsyte.auditUrl"
            ]
          },
          {
            "id": "codeLens",
            "title": "Right-click any URL in your code",
            "description": "Screenshot and Audit CodeLens actions appear above every URL in markdown, JS/TS, JSON, YAML, and HTML. You can also right-click the editor to run these actions on the URL under the cursor.",
            "media": {
              "markdown": "media/walkthrough/codelens.md"
            },
            "completionEvents": [
              "onCommand:deepsyte.takeScreenshotAtUrl",
              "onCommand:deepsyte.auditUrl",
              "onCommand:deepsyte.screenshotSelectedUrl",
              "onCommand:deepsyte.auditSelectedUrl"
            ]
          },
          {
            "id": "skills",
            "title": "Install agent skills",
            "description": "deepsyte ships skills (SKILL.md + workflows) that teach AI agents how to drive the tools. Install one from the sidebar or scaffold your own.\n[Open Sidebar](command:workbench.view.extension.deepsyte) \u00b7 [Create Skill](command:deepsyte.createSkill)",
            "media": {
              "markdown": "media/walkthrough/skills.md"
            },
            "completionEvents": [
              "onCommand:deepsyte.installSkill",
              "onCommand:deepsyte.previewSkill",
              "onCommand:deepsyte.createSkill"
            ]
          }
        ]
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": ["**/.deepsyte/urls.json", ".deepsyte.urls.json"],
        "url": "./schemas/urls.schema.json"
      },
      {
        "fileMatch": ["**/.deepsyte/budget.json", ".deepsyte.budget.json"],
        "url": "./schemas/budget.schema.json"
      }
    ],
    "snippets": [
      { "language": "javascript", "path": "./snippets/magicComments.code-snippets" },
      { "language": "typescript", "path": "./snippets/magicComments.code-snippets" },
      { "language": "javascriptreact", "path": "./snippets/magicComments.code-snippets" },
      { "language": "typescriptreact", "path": "./snippets/magicComments.code-snippets" },
      { "language": "python", "path": "./snippets/magicComments.code-snippets" },
      { "language": "ruby", "path": "./snippets/magicComments.code-snippets" },
      { "language": "go", "path": "./snippets/magicComments.code-snippets" },
      { "language": "rust", "path": "./snippets/magicComments.code-snippets" },
      { "language": "java", "path": "./snippets/magicComments.code-snippets" },
      { "language": "csharp", "path": "./snippets/magicComments.code-snippets" },
      { "language": "php", "path": "./snippets/magicComments.code-snippets" },
      { "language": "html", "path": "./snippets/magicComments.code-snippets" },
      { "language": "markdown", "path": "./snippets/magicComments.code-snippets" },
      { "language": "yaml", "path": "./snippets/magicComments.code-snippets" },
      { "language": "shellscript", "path": "./snippets/magicComments.code-snippets" }
    ],
    "configuration": {
      "title": "deepsyte",
      "properties": {
        "deepsyte.apiUrl": {
          "type": "string",
          "default": "https://deepsyte-api-production.up.railway.app",
          "description": "Base API URL for deepsyte."
        },
        "deepsyte.dashboardUrl": {
          "type": "string",
          "default": "https://www.deepsyte.com/dashboard",
          "description": "Dashboard URL opened by the extension."
        },
        "deepsyte.keysUrl": {
          "type": "string",
          "default": "https://www.deepsyte.com/dashboard/keys",
          "description": "URL used to retrieve deepsyte API keys."
        },
        "deepsyte.codeLens.urlActions": {
          "type": "boolean",
          "default": true,
          "description": "Show 📸 Screenshot and 🔍 Audit CodeLens actions above URLs in supported files."
        },
        "deepsyte.screenshot.width": {
          "type": "integer",
          "default": 1280,
          "minimum": 320,
          "maximum": 3840,
          "description": "Default viewport width (px) for screenshots triggered from this editor."
        },
        "deepsyte.screenshot.height": {
          "type": "integer",
          "default": 800,
          "minimum": 240,
          "maximum": 2160,
          "description": "Default viewport height (px) for screenshots triggered from this editor."
        },
        "deepsyte.screenshot.fullPage": {
          "type": "boolean",
          "default": true,
          "description": "Capture the entire scrollable page by default."
        },
        "deepsyte.screenshot.delay": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "maximum": 10000,
          "description": "Delay in ms after page load before capturing (useful for SPAs)."
        },
        "deepsyte.screenshot.format": {
          "type": "string",
          "enum": ["png", "jpeg", "webp"],
          "default": "png",
          "description": "Image format for screenshots."
        }
      }
    }
  },
  "devDependencies": {
    "@deepsyte/types": "*",
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.105.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
