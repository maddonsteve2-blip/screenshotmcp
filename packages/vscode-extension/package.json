{
  "name": "screenshotsmcp-vscode",
  "displayName": "ScreenshotsMCP",
  "description": "VS Code extension for ScreenshotsMCP: automatic browser OAuth, API key fallback, MCP registration, screenshot commands, and browser tooling.",
  "version": "0.22.0",
  "publisher": "ScreenshotMCP",
  "license": "SEE LICENSE IN LICENSE",
  "private": false,
  "preview": true,
  "pricing": "Free",
  "icon": "images/icon.png",
  "homepage": "https://www.screenshotmcp.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/stevejford/screenshotmcp.git",
    "directory": "packages/vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/stevejford/screenshotmcp/issues"
  },
  "markdown": "github",
  "files": [
    "dist/**",
    "images/**",
    "media/**",
    "snippets/**",
    "schemas/**",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "screenshots",
    "mcp",
    "browser",
    "automation",
    "testing",
    "playwright",
    "seo",
    "accessibility"
  ],
  "activationEvents": [
    "onUri",
    "workspaceContains:**/.vscode/mcp.json",
    "workspaceContains:**/.cursor/mcp.json"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "npm run build",
    "package:vsix": "npx @vscode/vsce package --no-dependencies",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/**/*.test.ts"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "screenshotsmcp",
          "title": "ScreenshotsMCP",
          "icon": "images/camera.svg"
        }
      ]
    },
    "views": {
      "screenshotsmcp": [
        {
          "id": "screenshotsmcp.sidebar",
          "name": "Home",
          "icon": "images/icon.png"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "screenshotsmcp.chat",
        "fullName": "ScreenshotsMCP",
        "name": "screenshotsmcp",
        "description": "Capture screenshots, run UX audits, and open packaged workflows.",
        "isSticky": true,
        "commands": [
          {
            "name": "screenshot",
            "description": "Capture a screenshot of a URL (usage: /screenshot https://example.com)"
          },
          {
            "name": "audit",
            "description": "Run a UX/SEO/accessibility audit (usage: /audit https://example.com)"
          },
          {
            "name": "workflow",
            "description": "Open a packaged workflow from an installed skill"
          },
          {
            "name": "timeline",
            "description": "Show recent screenshots and audits"
          },
          {
            "name": "diff",
            "description": "Visual diff between two URLs (usage: /diff https://a https://b)"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "screenshotsmcp.signIn",
        "title": "ScreenshotsMCP: Sign In"
      },
      {
        "command": "screenshotsmcp.signOut",
        "title": "ScreenshotsMCP: Sign Out"
      },
      {
        "command": "screenshotsmcp.checkStatus",
        "title": "ScreenshotsMCP: Check Status"
      },
      {
        "command": "screenshotsmcp.installMcpServer",
        "title": "ScreenshotsMCP: Configure Editor Integration"
      },
      {
        "command": "screenshotsmcp.syncCoreSkill",
        "title": "ScreenshotsMCP: Sync Core Skill"
      },
      {
        "command": "screenshotsmcp.browseSkills",
        "title": "ScreenshotsMCP: Browse Community Skills"
      },
      {
        "command": "screenshotsmcp.installSkill",
        "title": "ScreenshotsMCP: Install Skill"
      },
      {
        "command": "screenshotsmcp.previewSkill",
        "title": "ScreenshotsMCP: Preview Skill"
      },
      {
        "command": "screenshotsmcp.takeScreenshot",
        "title": "ScreenshotsMCP: Take Screenshot"
      },
      {
        "command": "screenshotsmcp.takeScreenshotAtUrl",
        "title": "ScreenshotsMCP: Take Screenshot of URL"
      },
      {
        "command": "screenshotsmcp.auditUrl",
        "title": "ScreenshotsMCP: Audit URL"
      },
      {
        "command": "screenshotsmcp.screenshotSelectedUrl",
        "title": "ScreenshotsMCP: Screenshot Selected URL"
      },
      {
        "command": "screenshotsmcp.auditSelectedUrl",
        "title": "ScreenshotsMCP: Audit Selected URL"
      },
      {
        "command": "screenshotsmcp.openTimeline",
        "title": "ScreenshotsMCP: Open Timeline"
      },
      {
        "command": "screenshotsmcp.openDashboard",
        "title": "ScreenshotsMCP: Open Dashboard"
      },
      {
        "command": "screenshotsmcp.createSkill",
        "title": "ScreenshotsMCP: Create New Skill"
      },
      {
        "command": "screenshotsmcp.showOutput",
        "title": "ScreenshotsMCP: Show Output"
      },
      {
        "command": "screenshotsmcp.showQuickActions",
        "title": "ScreenshotsMCP: Quick Actions"
      },
      {
        "command": "screenshotsmcp.openWorkflow",
        "title": "ScreenshotsMCP: Open Workflow"
      },
      {
        "command": "screenshotsmcp.clearAuditDiagnostics",
        "title": "ScreenshotsMCP: Clear Audit Diagnostics"
      },
      {
        "command": "screenshotsmcp.showUrlHistory",
        "title": "ScreenshotsMCP: Show URL History"
      },
      {
        "command": "screenshotsmcp.showHistoryForSelectedUrl",
        "title": "ScreenshotsMCP: Show History for Selected URL"
      },
      {
        "command": "screenshotsmcp.diffUrls",
        "title": "ScreenshotsMCP: Visual Diff (compare two URLs)"
      },
      {
        "command": "screenshotsmcp.editProjectUrls",
        "title": "ScreenshotsMCP: Edit Project URLs (.screenshotsmcp/urls.json)"
      },
      {
        "command": "screenshotsmcp.runProjectUrls",
        "title": "ScreenshotsMCP: Screenshot Project URLs"
      },
      {
        "command": "screenshotsmcp.auditProjectUrls",
        "title": "ScreenshotsMCP: Audit Project URLs"
      },
      {
        "command": "screenshotsmcp.openHtmlReport",
        "title": "ScreenshotsMCP: Open HTML Report"
      },
      {
        "command": "screenshotsmcp.captureBaseline",
        "title": "ScreenshotsMCP: Capture Baseline for URL"
      },
      {
        "command": "screenshotsmcp.diffBaseline",
        "title": "ScreenshotsMCP: Diff URL vs Stored Baseline"
      },
      {
        "command": "screenshotsmcp.editProjectBudget",
        "title": "ScreenshotsMCP: Edit Project Budget (.screenshotsmcp/budget.json)"
      },
      {
        "command": "screenshotsmcp.watchProjectUrls",
        "title": "ScreenshotsMCP: Watch Project URLs (run `screenshotsmcp watch`)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "screenshotsmcp.screenshotSelectedUrl",
          "group": "screenshotsmcp@1",
          "when": "editorHasSelection || editorTextFocus"
        },
        {
          "command": "screenshotsmcp.auditSelectedUrl",
          "group": "screenshotsmcp@2",
          "when": "editorHasSelection || editorTextFocus"
        },
        {
          "command": "screenshotsmcp.showHistoryForSelectedUrl",
          "group": "screenshotsmcp@3",
          "when": "editorHasSelection || editorTextFocus"
        }
      ]
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "screenshotsmcp.provider",
        "label": "ScreenshotsMCP"
      }
    ],
    "walkthroughs": [
      {
        "id": "screenshotsmcp.getStarted",
        "title": "Get started with ScreenshotsMCP",
        "description": "Sign in, take your first screenshot, and run your first audit — all from VS Code.",
        "steps": [
          {
            "id": "signIn",
            "title": "Sign in to ScreenshotsMCP",
            "description": "Sign in with your browser (OAuth) or paste an API key.\n[Sign In](command:screenshotsmcp.signIn)",
            "media": {
              "markdown": "media/walkthrough/sign-in.md"
            },
            "completionEvents": [
              "onCommand:screenshotsmcp.signIn"
            ]
          },
          {
            "id": "firstScreenshot",
            "title": "Take your first screenshot",
            "description": "Capture any URL — the result opens inline with open, copy, rerun, and dashboard actions.\n[Take Screenshot](command:screenshotsmcp.takeScreenshot)",
            "media": {
              "markdown": "media/walkthrough/screenshot.md"
            },
            "completionEvents": [
              "onCommand:screenshotsmcp.takeScreenshot"
            ]
          },
          {
            "id": "firstAudit",
            "title": "Run your first audit",
            "description": "Run a UX review on any URL. Findings render as a structured report with a hero screenshot and dashboard deep-link.\n[Audit URL](command:screenshotsmcp.showQuickActions)",
            "media": {
              "markdown": "media/walkthrough/audit.md"
            },
            "completionEvents": [
              "onCommand:screenshotsmcp.auditUrl"
            ]
          },
          {
            "id": "codeLens",
            "title": "Right-click any URL in your code",
            "description": "Screenshot and Audit CodeLens actions appear above every URL in markdown, JS/TS, JSON, YAML, and HTML. You can also right-click the editor to run these actions on the URL under the cursor.",
            "media": {
              "markdown": "media/walkthrough/codelens.md"
            },
            "completionEvents": [
              "onCommand:screenshotsmcp.takeScreenshotAtUrl",
              "onCommand:screenshotsmcp.auditUrl",
              "onCommand:screenshotsmcp.screenshotSelectedUrl",
              "onCommand:screenshotsmcp.auditSelectedUrl"
            ]
          },
          {
            "id": "skills",
            "title": "Install agent skills",
            "description": "ScreenshotsMCP ships skills (SKILL.md + workflows) that teach AI agents how to drive the tools. Install one from the sidebar or scaffold your own.\n[Open Sidebar](command:workbench.view.extension.screenshotsmcp) \u00b7 [Create Skill](command:screenshotsmcp.createSkill)",
            "media": {
              "markdown": "media/walkthrough/skills.md"
            },
            "completionEvents": [
              "onCommand:screenshotsmcp.installSkill",
              "onCommand:screenshotsmcp.previewSkill",
              "onCommand:screenshotsmcp.createSkill"
            ]
          }
        ]
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": ["**/.screenshotsmcp/urls.json", ".screenshotsmcp.urls.json"],
        "url": "./schemas/urls.schema.json"
      },
      {
        "fileMatch": ["**/.screenshotsmcp/budget.json", ".screenshotsmcp.budget.json"],
        "url": "./schemas/budget.schema.json"
      }
    ],
    "snippets": [
      { "language": "javascript", "path": "./snippets/magicComments.code-snippets" },
      { "language": "typescript", "path": "./snippets/magicComments.code-snippets" },
      { "language": "javascriptreact", "path": "./snippets/magicComments.code-snippets" },
      { "language": "typescriptreact", "path": "./snippets/magicComments.code-snippets" },
      { "language": "python", "path": "./snippets/magicComments.code-snippets" },
      { "language": "ruby", "path": "./snippets/magicComments.code-snippets" },
      { "language": "go", "path": "./snippets/magicComments.code-snippets" },
      { "language": "rust", "path": "./snippets/magicComments.code-snippets" },
      { "language": "java", "path": "./snippets/magicComments.code-snippets" },
      { "language": "csharp", "path": "./snippets/magicComments.code-snippets" },
      { "language": "php", "path": "./snippets/magicComments.code-snippets" },
      { "language": "html", "path": "./snippets/magicComments.code-snippets" },
      { "language": "markdown", "path": "./snippets/magicComments.code-snippets" },
      { "language": "yaml", "path": "./snippets/magicComments.code-snippets" },
      { "language": "shellscript", "path": "./snippets/magicComments.code-snippets" }
    ],
    "configuration": {
      "title": "ScreenshotsMCP",
      "properties": {
        "screenshotsmcp.apiUrl": {
          "type": "string",
          "default": "https://screenshotsmcp-api-production.up.railway.app",
          "description": "Base API URL for ScreenshotsMCP."
        },
        "screenshotsmcp.dashboardUrl": {
          "type": "string",
          "default": "https://www.screenshotmcp.com/dashboard",
          "description": "Dashboard URL opened by the extension."
        },
        "screenshotsmcp.keysUrl": {
          "type": "string",
          "default": "https://www.screenshotmcp.com/dashboard/keys",
          "description": "URL used to retrieve ScreenshotsMCP API keys."
        },
        "screenshotsmcp.codeLens.urlActions": {
          "type": "boolean",
          "default": true,
          "description": "Show 📸 Screenshot and 🔍 Audit CodeLens actions above URLs in supported files."
        },
        "screenshotsmcp.screenshot.width": {
          "type": "integer",
          "default": 1280,
          "minimum": 320,
          "maximum": 3840,
          "description": "Default viewport width (px) for screenshots triggered from this editor."
        },
        "screenshotsmcp.screenshot.height": {
          "type": "integer",
          "default": 800,
          "minimum": 240,
          "maximum": 2160,
          "description": "Default viewport height (px) for screenshots triggered from this editor."
        },
        "screenshotsmcp.screenshot.fullPage": {
          "type": "boolean",
          "default": true,
          "description": "Capture the entire scrollable page by default."
        },
        "screenshotsmcp.screenshot.delay": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "maximum": 10000,
          "description": "Delay in ms after page load before capturing (useful for SPAs)."
        },
        "screenshotsmcp.screenshot.format": {
          "type": "string",
          "enum": ["png", "jpeg", "webp"],
          "default": "png",
          "description": "Image format for screenshots."
        }
      }
    }
  },
  "devDependencies": {
    "@screenshotsmcp/types": "*",
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.105.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
