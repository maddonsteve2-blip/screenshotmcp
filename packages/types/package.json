{
  "name": "@screenshotsmcp/types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./skills": {
      "import": "./dist/skills.js",
      "types": "./dist/skills.d.ts"
    }
  },
  "scripts": {
    "prebuild": "node scripts/generate-skill-content.mjs",
    "build": "tsc -p tsconfig.json",
    "generate:skills": "node scripts/generate-skill-content.mjs",
    "sync:skills-to-web": "node scripts/sync-skills-to-web.mjs",
    "verify:skills": "node scripts/verify-skills.mjs",
    "lint:auth": "node --max-old-space-size=4096 ../../node_modules/typescript/bin/tsc -p tsconfig.auth.json"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
