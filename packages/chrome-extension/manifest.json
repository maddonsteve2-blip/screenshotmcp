{
  "manifest_version": 3,
  "name": "deepsyte — Full Page Screenshot",
  "short_name": "deepsyte",
  "version": "1.1.0",
  "description": "Capture full-page screenshots of any tab — including localhost. Download as PNG, JPG, or PDF. Annotate, copy, and save to cloud.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "downloads",
    "storage",
    "clipboardWrite",
    "offscreen",
    "contextMenus"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "capture-full-page": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Capture full page screenshot"
    },
    "capture-viewport": {
      "suggested_key": {
        "default": "Alt+Shift+V"
      },
      "description": "Capture screenshot"
    }
  }
}
