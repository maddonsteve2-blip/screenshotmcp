{
  "name": "screenshotsmcp",
  "version": "1.9.0",
  "description": "CLI for ScreenshotsMCP — take screenshots, record sessions, audit sites from the terminal",
  "type": "module",
  "bin": {
    "screenshotsmcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stevejford/screebshotmcp.git",
    "directory": "packages/cli"
  },
  "homepage": "https://www.screenshotmcp.com",
  "scripts": {
    "build": "node build.mjs",
    "lint:auth": "node --max-old-space-size=4096 ../../node_modules/typescript/bin/tsc -p tsconfig.auth.json",
    "prepublishOnly": "node build.mjs"
  },
  "keywords": [
    "screenshots",
    "mcp",
    "cli",
    "browser",
    "automation",
    "playwright",
    "screenshot",
    "web",
    "testing",
    "audit",
    "seo",
    "accessibility",
    "performance"
  ],
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@screenshotsmcp/types": "*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "open": "^10.1.0",
    "conf": "^13.0.1",
    "esbuild": "^0.24.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
