{
  "name": "screenshotsmcp",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "eval:agent": "node scripts/agent-eval.mjs",
    "lint": "turbo lint",
    "lint:auth": "npm --workspace @screenshotsmcp/api run lint:mcp-server && npm --workspace screenshotsmcp run lint:auth && npm --workspace @screenshotsmcp/types run lint:auth && npm --workspace @screenshotsmcp/web run lint:auth",
    "lint:quiet": "npm --workspace @screenshotsmcp/web run lint -- --quiet",
    "sync:onboarding": "node scripts/sync-onboarding-copy.mjs",
    "sync:onboarding:check": "node scripts/sync-onboarding-copy.mjs --check",
    "test:agent-eval": "node --test scripts/agent-eval.test.mjs",
    "test": "npm --prefix packages/vscode-extension run test",
    "test:chrome-extension:e2e": "node packages/chrome-extension/e2e/smoke.mjs",
    "typecheck": "turbo typecheck",
    "verify:auth": "npm run lint:auth && npm --workspace @screenshotsmcp/web run typecheck && npm --workspace screenshotsmcp run build",
    "verify:quiet": "npm run typecheck && npm run build && npm run lint:quiet && npm test",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20"
  }
}
